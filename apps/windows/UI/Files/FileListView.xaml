<UserControl x:Class="Rynat.WindowsClient.UI.Files.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:files="clr-namespace:Rynat.WindowsClient.UI.Files">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            Padding="12,14">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileList.PathTitle}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileList.LocationTitle}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="上级"
                        MinHeight="30"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Command="{Binding FileList.GoUpCommand}" />
                <Button Grid.Column="2"
                        Content="刷新"
                        MinHeight="30"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Command="{Binding FileList.RefreshCommand}" />
                <Button Grid.Column="3"
                        Content="新建文件夹"
                        MinHeight="30"
                        Padding="10,4"
                        Margin="0,0,12,0"
                        Command="{Binding FileList.CreateFolderCommand}" />
                <TextBlock Grid.Column="4"
                           Text="正在加载..."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FileList.IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox x:Name="SearchBox"
                         Grid.Column="5"
                         MinHeight="30"
                         Padding="8,4"
                         Text="{Binding FileList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchBox_OnKeyDown"
                         ToolTip="搜索当前目录" />
                <Button Grid.Column="6"
                        MinHeight="30"
                        Padding="10,4"
                        Margin="8,0,0,0"
                        Command="{Binding Preview.ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="预览" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Preview.IsVisible}" Value="True">
                                    <Setter Property="Content" Value="收起预览" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <ListView x:Name="FilesListView"
                      ItemsSource="{Binding FileList.Items}"
                      SelectedItem="{Binding FileList.SelectedItem, Mode=TwoWay}"
                      SelectionMode="Extended"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="ListView_OnPreviewMouseLeftButtonDown"
                      PreviewMouseMove="ListView_OnPreviewMouseMove"
                      DragOver="ListView_OnDragOver"
                      DragLeave="ListView_OnDragLeave"
                      Drop="ListView_OnDrop"
                      KeyDown="ListView_OnKeyDown"
                      MouseDoubleClick="ListView_OnMouseDoubleClick"
                      PreviewMouseRightButtonDown="ListView_OnPreviewMouseRightButtonDown"
                      SelectionChanged="ListView_OnSelectionChanged"
                      BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="MinHeight" Value="30" />
                        <Setter Property="Padding" Value="4,2" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RemoteDropState}" Value="{x:Static files:RemoteDropState.ValidTarget}">
                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="剪切"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="复制"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CopyFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="粘贴"
                                  Command="{Binding PlacementTarget.DataContext.FileList.PasteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <MenuItem Header="复制链接"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CopyLinkCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="重命名"
                                  Command="{Binding PlacementTarget.DataContext.FileList.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <MenuItem Header="删除"
                                  Command="{Binding PlacementTarget.DataContext.FileList.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名称" Width="320">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="类型"
                                        Width="110"
                                        DisplayMemberBinding="{Binding Type}" />
                        <GridViewColumn Header="大小"
                                        Width="100"
                                        DisplayMemberBinding="{Binding Size}" />
                        <GridViewColumn Header="修改时间"
                                        Width="160"
                                        DisplayMemberBinding="{Binding ModifiedAt}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>
    </Border>
</UserControl>
