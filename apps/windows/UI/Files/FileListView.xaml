<UserControl x:Class="Rynat.WindowsClient.UI.Files.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:files="clr-namespace:Rynat.WindowsClient.UI.Files">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            Padding="14,12">
            <ListView x:Name="FilesListView"
                      ItemsSource="{Binding FileList.Items}"
                      SelectedItem="{Binding FileList.SelectedItem, Mode=TwoWay}"
                      SelectionMode="Extended"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="ListView_OnPreviewMouseLeftButtonDown"
                      PreviewMouseMove="ListView_OnPreviewMouseMove"
                      DragOver="ListView_OnDragOver"
                      DragLeave="ListView_OnDragLeave"
                      Drop="ListView_OnDrop"
                      KeyDown="ListView_OnKeyDown"
                      MouseDoubleClick="ListView_OnMouseDoubleClick"
                      PreviewMouseRightButtonDown="ListView_OnPreviewMouseRightButtonDown"
                      SelectionChanged="ListView_OnSelectionChanged"
                      BorderThickness="0"
                      Background="{StaticResource PanelBackgroundBrush}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource RynatListViewItemStyle}">
                        <Setter Property="MinHeight" Value="36" />
                        <Setter Property="Padding" Value="8,4" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RemoteDropState}" Value="{x:Static files:RemoteDropState.ValidTarget}">
                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="新建文件夹"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CreateFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <MenuItem Header="剪切"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="复制"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CopyFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="粘贴"
                                  Command="{Binding PlacementTarget.DataContext.FileList.PasteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <MenuItem Header="复制链接"
                                  Command="{Binding PlacementTarget.DataContext.FileList.CopyLinkCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="重命名"
                                  Command="{Binding PlacementTarget.DataContext.FileList.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <MenuItem Header="删除"
                                  Command="{Binding PlacementTarget.DataContext.FileList.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名称" Width="320">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="类型"
                                        Width="110"
                                        DisplayMemberBinding="{Binding Type}" />
                        <GridViewColumn Header="大小"
                                        Width="100"
                                        DisplayMemberBinding="{Binding Size}" />
                        <GridViewColumn Header="修改时间"
                                        Width="160"
                                        DisplayMemberBinding="{Binding ModifiedAt}" />
                    </GridView>
                </ListView.View>
            </ListView>
    </Border>
</UserControl>
