<Window x:Class="Rynat.WindowsClient.UI.Servers.ServerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器设置"
        Width="640"
        Height="420"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,12,0,0">
                    <Button Content="新增"
                            MinWidth="72"
                            Command="{Binding AddCommand}" />
                    <Button Content="删除"
                            MinWidth="72"
                            Margin="8,0,0,0"
                            Command="{Binding RemoveCommand}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Servers}"
                         SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                         BorderThickness="1"
                         BorderBrush="{StaticResource BorderBrush}"
                         Background="{StaticResource PanelBackgroundBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Margin="4,4">
                                <TextBlock Text="✓"
                                           Width="20">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Hidden" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <StackPanel Grid.Column="2"
                        DataContext="{Binding SelectedServer}">
                <TextBlock Text="服务器详情"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,18" />
                <TextBlock Text="名称"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14" />
                <TextBlock Text="地址"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,18" />
                <Button Content="设为默认服务器"
                        HorizontalAlignment="Left"
                        Command="{Binding DataContext.SetActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Text="{Binding Message}"
                       Style="{StaticResource CaptionTextStyle}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <StackPanel Grid.Row="1"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="保存"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="84"
                        Command="{Binding SaveCommand}" />
                <Button Content="完成"
                        MinWidth="84"
                        Margin="8,0,0,0"
                        Command="{Binding CloseCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
