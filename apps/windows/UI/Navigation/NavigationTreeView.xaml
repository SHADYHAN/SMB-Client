<UserControl x:Class="Rynat.WindowsClient.UI.Navigation.NavigationTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navigation="clr-namespace:Rynat.WindowsClient.UI.Navigation">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            Padding="12,14">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="共享"
                       FontWeight="SemiBold"
                       Margin="4,0,0,12" />
            <TreeView ItemsSource="{Binding Roots}"
                      SelectedItemChanged="TreeView_OnSelectedItemChanged"
                      MouseDoubleClick="TreeView_OnMouseDoubleClick"
                      AllowDrop="True"
                      DragOver="TreeView_OnDragOver"
                      DragLeave="TreeView_OnDragLeave"
                      Drop="TreeView_OnDrop"
                      BorderThickness="0"
                      Background="Transparent">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RemoteDropState}" Value="{x:Static navigation:NavigationDropState.ValidTarget}">
                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type navigation:NavigationNodeViewModel}"
                                              ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Title}"
                                   Padding="4,3" />
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </DockPanel>
    </Border>
</UserControl>
