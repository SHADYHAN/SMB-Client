<UserControl x:Class="Rynat.WindowsClient.UI.Navigation.NavigationTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navigation="clr-namespace:Rynat.WindowsClient.UI.Navigation">
    <Border Background="{StaticResource PanelBackgroundBrush}">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Height="36"
                  Background="{StaticResource PanelBackgroundBrush}">
                <Border Background="{StaticResource ControlHoverBrush}"
                        CornerRadius="7"
                        Padding="2"
                        Margin="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="共享"
                                Command="{Binding ShowSharesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSharesTabActive}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="1"
                                Content="收藏"
                                Command="{Binding ShowFavoritesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavoritesTabActive}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
            <TreeView ItemsSource="{Binding Roots}"
                      SelectedItemChanged="TreeView_OnSelectedItemChanged"
                      MouseDoubleClick="TreeView_OnMouseDoubleClick"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="8,6">
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSharesTabActive}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource RynatTreeViewItemStyle}">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type navigation:NavigationNodeViewModel}"
                                              ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis"
                                   Padding="4,2" />
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
            <ListView x:Name="FavoritesListView"
                      ItemsSource="{Binding Favorites}"
                      MouseDoubleClick="FavoritesList_OnMouseDoubleClick"
                      KeyDown="FavoritesList_OnKeyDown"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="8,6">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFavoritesTabActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="打开收藏"
                                  Click="FavoriteOpenMenuItem_OnClick" />
                        <MenuItem Header="取消收藏"
                                  Command="{Binding PlacementTarget.DataContext.RemoveFavoriteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type navigation:FavoriteLinkViewModel}">
                        <StackPanel Margin="2,4">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Location}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>
    </Border>
</UserControl>
