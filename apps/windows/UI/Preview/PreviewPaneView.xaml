<UserControl x:Class="Rynat.WindowsClient.UI.Preview.PreviewPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            Padding="16">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="预览"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="收起"
                        MinHeight="28"
                        Padding="10,4"
                        Command="{Binding ToggleCommand}" />
            </Grid>

            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Subtitle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,18" />
                <Border Height="210"
                        Background="{StaticResource SubtleBackgroundBrush}"
                        CornerRadius="12">
                    <TextBlock Text="{Binding ContentType, TargetNullValue=暂无预览}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
