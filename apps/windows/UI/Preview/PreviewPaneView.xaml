<UserControl x:Class="Rynat.WindowsClient.UI.Preview.PreviewPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            Padding="16">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="预览"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="复制链接"
                        MinHeight="28"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Command="{Binding CopyLinkCommand}" />
                <Button Grid.Column="2"
                        Content="收起"
                        MinHeight="28"
                        Padding="10,4"
                        Command="{Binding ToggleCommand}" />
            </Grid>

            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Subtitle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,18" />
                <Grid Height="240"
                      ClipToBounds="True">
                    <Border Background="{StaticResource SubtleBackgroundBrush}"
                            CornerRadius="12" />
                    <Image Source="{Binding LocalImageUri}"
                           Stretch="Uniform"
                           Margin="10">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <MediaElement x:Name="VideoPreview"
                                  Source="{Binding LocalVideoUri}"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  Margin="10">
                        <MediaElement.Style>
                            <Style TargetType="MediaElement">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasVideoPreview}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </MediaElement.Style>
                    </MediaElement>
                    <Button x:Name="VideoPlayButton"
                            Content="播放"
                            Width="64"
                            Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="VideoPlayButton_OnClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasVideoPreview}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="{Binding PreviewText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPreviewMedia}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
