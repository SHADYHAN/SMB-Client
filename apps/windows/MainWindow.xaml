<Window x:Class="Rynat.WindowsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:files="clr-namespace:Rynat.WindowsClient.UI.Files"
        xmlns:login="clr-namespace:Rynat.WindowsClient.UI.Login"
        xmlns:navigation="clr-namespace:Rynat.WindowsClient.UI.Navigation"
        xmlns:preview="clr-namespace:Rynat.WindowsClient.UI.Preview"
        xmlns:status="clr-namespace:Rynat.WindowsClient.UI.Status"
        Title="rynat 共享网盘"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <login:LoginView DataContext="{Binding Login}" />
        </Grid>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="268" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition x:Name="PreviewColumn" Width="320" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="14,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="236" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.GoUpCommand}"
                            ToolTip="返回上级">
                        <TextBlock Text="{StaticResource IconBack}"
                                   Style="{StaticResource HeaderGlyphStyle}" />
                    </Button>
                    <Button Grid.Column="1"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.GoShareRootCommand}"
                            ToolTip="共享根目录">
                        <TextBlock Text="{StaticResource IconHome}"
                                   Style="{StaticResource HeaderGlyphStyle}" />
                    </Button>
                    <TextBlock Grid.Column="2"
                               Text="{Binding FileList.BreadcrumbText}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding FileList.LocationTitle}" />
                    <TextBox x:Name="WorkspaceSearchBox"
                             Grid.Column="3"
                             MinHeight="30"
                             Padding="8,4"
                             Margin="12,0,8,0"
                             Background="{StaticResource ControlBackgroundBrush}"
                             Text="{Binding FileList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             KeyDown="WorkspaceSearchBox_OnKeyDown"
                             ToolTip="搜索已加载目录" />
                    <Button Grid.Column="4"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.RefreshCommand}"
                            ToolTip="刷新">
                        <TextBlock Text="{StaticResource IconRefresh}"
                                   Style="{StaticResource HeaderGlyphStyle}" />
                    </Button>
                    <Button Grid.Column="5"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Command="{Binding Preview.ToggleCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                <Setter Property="ToolTip" Value="打开预览面板" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Preview.IsVisible}" Value="True">
                                        <Setter Property="ToolTip" Value="关闭预览面板" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource HeaderGlyphStyle}">
                                    <Setter Property="Text" Value="{StaticResource IconPreviewShow}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Preview.IsVisible}" Value="True">
                                            <Setter Property="Text" Value="{StaticResource IconPreviewHide}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button x:Name="HeaderUserMenuButton"
                            Grid.Column="6"
                            Style="{StaticResource HeaderUserButtonStyle}"
                            VerticalAlignment="Center"
                            Click="HeaderUserMenuButton_OnClick"
                            ToolTip="用户菜单">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource IconUser}"
                                       Style="{StaticResource HeaderGlyphStyle}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="{Binding HeaderUserLabel}"
                                       MaxWidth="120"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{StaticResource IconChevronDown}"
                                       Style="{StaticResource HeaderGlyphStyle}"
                                       FontSize="10"
                                       Margin="8,1,0,0" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{Binding PlacementTarget.DataContext.HeaderUserLabel, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          IsEnabled="False" />
                                <Separator />
                                <MenuItem Header="服务器设置..."
                                          Command="{Binding PlacementTarget.DataContext.Login.ServerSettingsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="退出登录"
                                          Command="{Binding PlacementTarget.DataContext.LogoutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{StaticResource PanelAltBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <navigation:NavigationTreeView DataContext="{Binding Navigation}" />
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Background="{StaticResource PanelBackgroundBrush}">
                <files:FileListView />
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="2"
                    Background="{StaticResource PanelAltBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <preview:PreviewPaneView DataContext="{Binding Preview}">
                    <preview:PreviewPaneView.Style>
                        <Style TargetType="preview:PreviewPaneView">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </preview:PreviewPaneView.Style>
                </preview:PreviewPaneView>
            </Border>
            <status:StatusBarView Grid.Row="2"
                                  Grid.ColumnSpan="3"
                                  DataContext="{Binding Status}" />
        </Grid>
    </Grid>
</Window>
