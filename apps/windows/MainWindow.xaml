<Window x:Class="Rynat.WindowsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:files="clr-namespace:Rynat.WindowsClient.UI.Files"
        xmlns:login="clr-namespace:Rynat.WindowsClient.UI.Login"
        xmlns:navigation="clr-namespace:Rynat.WindowsClient.UI.Navigation"
        xmlns:preview="clr-namespace:Rynat.WindowsClient.UI.Preview"
        xmlns:status="clr-namespace:Rynat.WindowsClient.UI.Status"
        Title="rynat 共享网盘"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <login:LoginView DataContext="{Binding Login}" />
        </Grid>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition x:Name="PreviewColumn" Width="320" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Background="{StaticResource SubtleBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="236" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="‹"
                            Width="32"
                            MinHeight="30"
                            Padding="0"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.GoUpCommand}"
                            ToolTip="返回上级" />
                    <Button Grid.Column="1"
                            Content="⌂"
                            Width="32"
                            MinHeight="30"
                            Padding="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.GoShareRootCommand}"
                            ToolTip="共享根目录" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding FileList.BreadcrumbText}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding FileList.LocationTitle}" />
                    <TextBox x:Name="WorkspaceSearchBox"
                             Grid.Column="3"
                             MinHeight="30"
                             Padding="8,4"
                             Margin="12,0,8,0"
                             Text="{Binding FileList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             KeyDown="WorkspaceSearchBox_OnKeyDown"
                             ToolTip="搜索已加载目录" />
                    <Button Grid.Column="4"
                            Content="↻"
                            Width="32"
                            MinHeight="30"
                            Padding="0"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.RefreshCommand}"
                            ToolTip="刷新" />
                    <Button Grid.Column="5"
                            Width="32"
                            MinHeight="30"
                            Padding="0"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Command="{Binding Preview.ToggleCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="▯" />
                                <Setter Property="ToolTip" Value="打开预览面板" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Preview.IsVisible}" Value="True">
                                        <Setter Property="Content" Value="▰" />
                                        <Setter Property="ToolTip" Value="关闭预览面板" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="6"
                            Content="新建文件夹"
                            MinHeight="30"
                            Padding="10,4"
                            VerticalAlignment="Center"
                            Command="{Binding FileList.CreateFolderCommand}" />
                </Grid>
            </Border>

            <navigation:NavigationTreeView Grid.Row="1"
                                           Grid.Column="0"
                                           DataContext="{Binding Navigation}" />
            <files:FileListView Grid.Row="1"
                                Grid.Column="1" />
            <preview:PreviewPaneView Grid.Row="1"
                                     Grid.Column="2"
                                     DataContext="{Binding Preview}">
                <preview:PreviewPaneView.Style>
                    <Style TargetType="preview:PreviewPaneView">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </preview:PreviewPaneView.Style>
            </preview:PreviewPaneView>
            <status:StatusBarView Grid.Row="2"
                                  Grid.ColumnSpan="3"
                                  DataContext="{Binding Status}" />
        </Grid>
    </Grid>
</Window>
