<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Rynat.WindowsClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Rynat.WindowsClient.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{x:Bind ViewModel.WindowTitle, Mode=OneWay}">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource RynatCanvasBrush}">
        <Grid
            x:Name="LoginView"
            Visibility="{x:Bind ViewModel.IsLoginVisible, Mode=OneWay}">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF7FBFF" Offset="0" />
                    <GradientStop Color="#FFE2EEFF" Offset="0.58" />
                    <GradientStop Color="#FFF6FAF7" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse
                Width="560"
                Height="560"
                Margin="-180,-230,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Fill="#242F6FD8" />
            <Ellipse
                Width="420"
                Height="420"
                Margin="0,0,-150,-150"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Fill="#1E36A878" />
            <Grid
                Width="430"
                Height="270"
                Margin="0,0,64,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Opacity="0.55">
                <Border
                    Background="#38FFFFFF"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24" />
                <StackPanel
                    Margin="48,42"
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Bottom">
                    <Border Width="56" Height="142" Background="#33FFFFFF" CornerRadius="14" />
                    <Border Width="56" Height="198" Background="#40FFFFFF" CornerRadius="14" />
                    <Border Width="56" Height="230" Background="#36FFFFFF" CornerRadius="14" />
                    <Border Width="56" Height="176" Background="#42FFFFFF" CornerRadius="14" />
                    <Border Width="56" Height="208" Background="#34FFFFFF" CornerRadius="14" />
                </StackPanel>
                <Border
                    Width="250"
                    Height="68"
                    Margin="0,0,0,42"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Background="#4DFFFFFF"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18" />
            </Grid>

            <Border
                Width="376"
                Padding="36,30,36,26"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource RynatGlassBrush}"
                BorderBrush="#47FFFFFF"
                BorderThickness="1"
                CornerRadius="18">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>

                <Grid>
                    <Button
                        Width="28"
                        Height="28"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="ServerSettingsButton_Click"
                        Style="{StaticResource RynatToolbarButtonStyle}"
                        ToolTipService.ToolTip="服务器设置">
                        <FontIcon FontSize="15" Glyph="&#xE713;" />
                    </Button>

                    <StackPanel
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        Spacing="22">
                        <StackPanel
                            HorizontalAlignment="Center"
                            Spacing="7">
                            <Image
                                Width="54"
                                Height="58"
                                Source="Assets/RYNATLogo.png"
                                Stretch="Uniform" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="19"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource RynatInkBrush}"
                                Text="RYNAT 共享网盘" />
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <Border
                                Width="304"
                                Height="44"
                                Background="Transparent"
                                Tapped="UsernameFieldFrame_Tapped">
                                <Border
                                    x:Name="UsernameFieldFrame"
                                    Margin="1"
                                    Background="{ThemeResource RynatLoginFieldBrush}"
                                    BorderBrush="{ThemeResource RynatLoginFieldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <Grid ColumnSpacing="11" Padding="15,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            x:Name="UsernameFieldIcon"
                                            Grid.Column="0"
                                            FontSize="14"
                                            Foreground="{ThemeResource RynatFaintBrush}"
                                            Glyph="&#xE77B;"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,1,0,0"
                                            IsHitTestVisible="False" />
                                        <TextBox
                                            x:Name="UsernameInput"
                                            Grid.Column="1"
                                            GotFocus="LoginTextInput_GotFocus"
                                            KeyDown="LoginTextInput_KeyDown"
                                            LostFocus="LoginTextInput_LostFocus"
                                            PlaceholderText="用户名"
                                            Style="{StaticResource RynatLoginTextBoxStyle}"
                                            Text="{x:Bind ViewModel.ManualUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Resources>
                                                <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                                <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#FF718096" />
                                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#FF718096" />
                                            </TextBox.Resources>
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </Border>
                            <Border
                                Width="304"
                                Height="44"
                                Background="Transparent"
                                Tapped="PasswordFieldFrame_Tapped">
                                <Border
                                    x:Name="PasswordFieldFrame"
                                    Margin="1"
                                    Background="{ThemeResource RynatLoginFieldBrush}"
                                    BorderBrush="{ThemeResource RynatLoginFieldBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <Grid ColumnSpacing="11" Padding="15,0,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            x:Name="PasswordFieldIcon"
                                            Grid.Column="0"
                                            FontSize="14"
                                            Foreground="{ThemeResource RynatFaintBrush}"
                                            Glyph="&#xE72E;"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,1,0,0"
                                            IsHitTestVisible="False" />
                                        <PasswordBox
                                            x:Name="PasswordInput"
                                            Grid.Column="1"
                                            GotFocus="LoginTextInput_GotFocus"
                                            KeyDown="LoginTextInput_KeyDown"
                                            LostFocus="LoginTextInput_LostFocus"
                                            PasswordChanged="PasswordInput_PasswordChanged"
                                            PasswordRevealMode="Hidden"
                                            PlaceholderText="密码"
                                            Style="{StaticResource RynatLoginPasswordBoxStyle}">
                                            <PasswordBox.Resources>
                                                <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                                <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#FF718096" />
                                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#FF718096" />
                                            </PasswordBox.Resources>
                                        </PasswordBox>
                                    </Grid>
                                </Border>
                            </Border>

                            <Grid>
                                <Grid.Width>304</Grid.Width>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox
                                    Content="记住密码"
                                    IsChecked="{x:Bind ViewModel.RememberPassword, Mode=TwoWay}" />
                                <CheckBox
                                    Grid.Column="1"
                                    Content="自动登录"
                                    IsChecked="{x:Bind ViewModel.AutoLogin, Mode=TwoWay}" />
                            </Grid>

                            <Button
                                Width="304"
                                HorizontalAlignment="Center"
                                Click="LoginButton_Click"
                                Content="登录"
                                IsEnabled="{x:Bind ViewModel.CanLogin, Mode=OneWay}"
                                Style="{StaticResource RynatPrimaryButtonStyle}" />

                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{x:Bind ViewModel.IsAutoLoginConnecting, Mode=OneWay}">
                                <ProgressRing
                                    Width="18"
                                    Height="18"
                                    IsActive="True" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource RynatMutedTextStyle}"
                                    Text="正在自动登录..." />
                            </StackPanel>

                            <TextBlock
                                MaxLines="2"
                                Style="{StaticResource RynatMutedTextStyle}"
                                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="WorkspaceView"
            RowSpacing="0"
            Visibility="{x:Bind ViewModel.IsWorkspaceVisible, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Border
                Background="{ThemeResource RynatChromeBrush}"
                BorderBrush="Transparent"
                BorderThickness="0">
                <Grid Padding="14,0,16,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Click="NavigateUpButton_Click"
                        IsEnabled="{x:Bind ViewModel.CanNavigateUp, Mode=OneWay}"
                        Style="{StaticResource RynatToolbarButtonStyle}"
                        ToolTipService.ToolTip="返回上级">
                        <FontIcon FontSize="15" Glyph="&#xE72B;" />
                    </Button>
                    <Button
                        Grid.Column="1"
                        Click="OpenShareRootButton_Click"
                        Style="{StaticResource RynatToolbarButtonStyle}"
                        ToolTipService.ToolTip="共享根目录">
                        <FontIcon FontSize="15" Glyph="&#xE80F;" />
                    </Button>

                    <Grid
                        Grid.Column="2"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource RynatInkBrush}"
                            MaxLines="1"
                            Text="{x:Bind ViewModel.BreadcrumbText, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Center">
                        <TextBox
                            PlaceholderText="搜索"
                            Style="{StaticResource RynatSearchTextBoxStyle}"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Resources>
                                <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FFFFFFFF" />
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FFECEFF5" />
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="4"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                        <Button
                            Click="RefreshDirectoryButton_Click"
                            Style="{StaticResource RynatToolbarButtonStyle}"
                            ToolTipService.ToolTip="刷新">
                            <FontIcon FontSize="15" Glyph="&#xE72C;" />
                        </Button>
                        <Button
                            Click="TogglePreviewButton_Click"
                            Style="{StaticResource RynatToolbarButtonStyle}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.PreviewToggleLabel, Mode=OneWay}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="20" Height="20">
                                    <Rectangle
                                        Canvas.Left="3.5"
                                        Canvas.Top="3.5"
                                        Width="13"
                                        Height="13"
                                        Fill="Transparent"
                                        RadiusX="2.3"
                                        RadiusY="2.3"
                                        Stroke="{ThemeResource RynatInkBrush}"
                                        StrokeThickness="1.7" />
                                    <Line
                                        X1="12.1"
                                        X2="12.1"
                                        Y1="4.1"
                                        Y2="15.9"
                                        Stroke="{ThemeResource RynatInkBrush}"
                                        StrokeThickness="1.5" />
                                    <Line
                                        X1="13.9"
                                        X2="15"
                                        Y1="7"
                                        Y2="7"
                                        Stroke="{ThemeResource RynatInkBrush}"
                                        StrokeThickness="1.2" />
                                    <Line
                                        X1="13.9"
                                        X2="15"
                                        Y1="9.6"
                                        Y2="9.6"
                                        Stroke="{ThemeResource RynatInkBrush}"
                                        StrokeThickness="1.2" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <Grid
                        Grid.Column="5"
                        ColumnSpacing="8"
                        VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressRing
                            Width="18"
                            Height="18"
                            IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.BusyIndicatorVisibility, Mode=OneWay}" />
                        <Button
                            Grid.Column="1"
                            MinWidth="88"
                            Style="{StaticResource RynatUserMenuButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <TextBlock Text="{x:Bind ViewModel.UserMenuTitle, Mode=OneWay}" />
                                <FontIcon
                                    FontSize="10"
                                    Glyph="&#xE70D;"
                                    Foreground="{ThemeResource RynatFaintBrush}" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem
                                        Click="ServerSettingsButton_Click"
                                        Text="服务器设置..." />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem
                                        Click="LogoutMenuItem_Click"
                                        Text="退出登录" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid
                x:Name="WorkspaceSplitGrid"
                Grid.Row="1"
                ColumnSpacing="0"
                Background="{ThemeResource RynatCanvasBrush}"
                SizeChanged="WorkspaceSplitGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarPaneColumn" Width="220" MinWidth="180" MaxWidth="320" />
                    <ColumnDefinition x:Name="SidebarSplitterColumn" Width="6" />
                    <ColumnDefinition x:Name="FilePaneColumn" Width="*" MinWidth="520" />
                    <ColumnDefinition x:Name="PreviewSplitterColumn" Width="6" />
                    <ColumnDefinition x:Name="PreviewPaneColumn" Width="340" MinWidth="280" MaxWidth="460" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{ThemeResource RynatSidebarBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            Margin="8,5,8,5"
                            Background="{ThemeResource RynatHoverBrush}"
                            CornerRadius="9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Margin="1"
                                Background="{ThemeResource RynatSelectionBrush}"
                                CornerRadius="6"
                                Visibility="{x:Bind ViewModel.IsShareSidebarActive, Mode=OneWay}" />
                            <Border
                                Grid.Column="1"
                                Margin="1"
                                Background="{ThemeResource RynatSelectionBrush}"
                                CornerRadius="6"
                                Visibility="{x:Bind ViewModel.IsFavoriteSidebarActive, Mode=OneWay}" />
                            <Button
                                Grid.Column="0"
                                Margin="0"
                                Click="ShareSidebarTab_Click"
                                Content="共享"
                                FontWeight="{x:Bind ViewModel.ShareSidebarTabFontWeight, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.ShareSidebarTabForeground, Mode=OneWay}"
                                Style="{StaticResource RynatSidebarTabButtonStyle}" />
                            <Button
                                Grid.Column="1"
                                Click="FavoriteSidebarTab_Click"
                                Content="收藏"
                                FontWeight="{x:Bind ViewModel.FavoriteSidebarTabFontWeight, Mode=OneWay}"
                                Foreground="{x:Bind ViewModel.FavoriteSidebarTabForeground, Mode=OneWay}"
                                Style="{StaticResource RynatSidebarTabButtonStyle}" />
                        </Grid>

                        <ListView
                            x:Name="SidebarListView"
                            Grid.Row="1"
                            DoubleTapped="SidebarListView_DoubleTapped"
                            Tapped="SidebarListView_Tapped"
                            ItemContainerStyle="{StaticResource RynatSidebarListViewItemStyle}"
                            ItemsSource="{x:Bind ViewModel.SidebarItems, Mode=OneWay}"
                            RightTapped="SidebarListView_RightTapped"
                            SelectedItem="{x:Bind ViewModel.SelectedSidebarItem, Mode=TwoWay}"
                            SelectionMode="Single">
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                                <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">False</x:Boolean>
                            </ListView.Resources>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection />
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel>
                                        <ItemsStackPanel.ChildrenTransitions>
                                            <TransitionCollection />
                                        </ItemsStackPanel.ChildrenTransitions>
                                    </ItemsStackPanel>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:Object">
                                    <Border
                                        MinHeight="34"
                                        Margin="0"
                                        Background="{Binding SelectionBrush}"
                                        CornerRadius="7">
                                        <Grid
                                            Height="34"
                                            Padding="{Binding RowPadding}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="9.5"
                                                Foreground="{ThemeResource RynatFaintBrush}"
                                                Text="{Binding ExpandGlyph}" />
                                            <FontIcon
                                                Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="13.5"
                                                Foreground="{Binding AccentBrush}"
                                                Glyph="{Binding IconGlyph}" />
                                            <Grid
                                                Grid.Column="2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource RynatInkBrush}"
                                                    MaxLines="1"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </Grid>
                </Border>

                <controls:ResizeSplitter
                    x:Name="SidebarPaneSplitter"
                    Grid.Column="1"
                    Background="Transparent"
                    PointerCanceled="SidebarPaneSplitter_PointerReleased"
                    PointerEntered="WorkspacePaneSplitter_PointerEntered"
                    PointerExited="WorkspacePaneSplitter_PointerExited"
                    PointerPressed="SidebarPaneSplitter_PointerPressed"
                    PointerReleased="SidebarPaneSplitter_PointerReleased"
                    PointerMoved="WorkspacePaneSplitter_PointerMoved">
                    <Border
                        x:Name="SidebarPaneSplitterLine"
                        Width="1"
                        HorizontalAlignment="Center"
                        Background="Transparent" />
                </controls:ResizeSplitter>

                    <Grid
                        x:Name="DirectoryContentGrid"
                        Grid.Column="2"
                        Margin="0,0,0,0"
                        Background="{ThemeResource RynatSurfaceBrush}"
                        SizeChanged="DirectoryContentGrid_SizeChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid
                        Padding="16,0,18,0"
                        Background="{ThemeResource RynatSurfaceBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="DirectoryNameColumn" Width="58*" MinWidth="180" />
                            <ColumnDefinition x:Name="DirectoryTypeColumn" Width="11*" MinWidth="64" />
                            <ColumnDefinition x:Name="DirectorySizeColumn" Width="12*" MinWidth="68" />
                            <ColumnDefinition x:Name="DirectoryModifiedColumn" Width="19*" MinWidth="146" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="{ThemeResource RynatMutedBrush}"
                            Text="名称" />
                        <controls:ResizeSplitter
                            x:Name="DirectoryNameColumnSplitter"
                            Width="10"
                            Margin="0,6,-5,6"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            PointerPressed="DirectoryColumnSplitter_PointerPressed"
                            PointerMoved="DirectoryColumnSplitter_PointerMoved"
                            PointerReleased="DirectoryColumnSplitter_PointerReleased"
                            PointerCanceled="DirectoryColumnSplitter_PointerReleased" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="{ThemeResource RynatMutedBrush}"
                            Text="类型" />
                        <controls:ResizeSplitter
                            x:Name="DirectoryTypeColumnSplitter"
                            Grid.Column="1"
                            Width="10"
                            Margin="0,6,-5,6"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            PointerPressed="DirectoryColumnSplitter_PointerPressed"
                            PointerMoved="DirectoryColumnSplitter_PointerMoved"
                            PointerReleased="DirectoryColumnSplitter_PointerReleased"
                            PointerCanceled="DirectoryColumnSplitter_PointerReleased" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="0,0,14,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="{ThemeResource RynatMutedBrush}"
                            Text="大小" />
                        <controls:ResizeSplitter
                            x:Name="DirectorySizeColumnSplitter"
                            Grid.Column="2"
                            Width="10"
                            Margin="0,6,-5,6"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            PointerPressed="DirectoryColumnSplitter_PointerPressed"
                            PointerMoved="DirectoryColumnSplitter_PointerMoved"
                            PointerReleased="DirectoryColumnSplitter_PointerReleased"
                            PointerCanceled="DirectoryColumnSplitter_PointerReleased" />
                        <TextBlock
                            Grid.Column="3"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="{ThemeResource RynatMutedBrush}"
                            Text="修改时间" />
                    </Grid>

                    <Border
                        Grid.Row="1"
                        x:Name="DirectoryDropTarget"
                        AllowDrop="True"
                        Background="{ThemeResource RynatSurfaceBrush}"
                        DragOver="DirectoryDropTarget_DragOver"
                        Drop="DirectoryDropTarget_Drop">
                        <ListView
                            x:Name="DirectoryItemsListView"
                            DoubleTapped="DirectoryItemsListView_DoubleTapped"
                            IsItemClickEnabled="False"
                            ItemContainerStyle="{StaticResource RynatDirectoryListViewItemStyle}"
                            ItemsSource="{x:Bind ViewModel.DirectoryItems, Mode=OneWay}"
                            KeyDown="DirectoryItemsListView_KeyDown"
                            RightTapped="DirectoryItemsListView_RightTapped"
                            SelectedItem="{x:Bind ViewModel.SelectedDirectoryItem, Mode=TwoWay}"
                            SelectionChanged="DirectoryItemsListView_SelectionChanged"
                            SelectionMode="Extended"
                            Tapped="DirectoryItemsListView_Tapped">
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#FFF3F8FF" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#FFE8F1FE" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#FFD4E6FF" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#FFC5DDFF" />
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#FFB7D4FB" />
                                <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#FF111827" />
                                <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="#FF111827" />
                                <CornerRadius x:Key="ListViewItemCornerRadius">8</CornerRadius>
                                <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">False</x:Boolean>
                            </ListView.Resources>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection />
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel>
                                        <ItemsStackPanel.ChildrenTransitions>
                                            <TransitionCollection />
                                        </ItemsStackPanel.ChildrenTransitions>
                                    </ItemsStackPanel>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:Object">
                                    <Grid>
                                        <Grid
                                            MinHeight="36"
                                            Padding="8,0,10,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding Width, ElementName=DirectoryNameColumn}" />
                                                <ColumnDefinition Width="{Binding Width, ElementName=DirectoryTypeColumn}" />
                                                <ColumnDefinition Width="{Binding Width, ElementName=DirectorySizeColumn}" />
                                                <ColumnDefinition Width="{Binding Width, ElementName=DirectoryModifiedColumn}" />
                                            </Grid.ColumnDefinitions>

                                            <Grid
                                                ColumnSpacing="10"
                                                VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="{Binding AccentBrush}"
                                                    Glyph="{Binding IconGlyph}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="{Binding NameFontWeight}"
                                                    Foreground="{ThemeResource RynatInkBrush}"
                                                    MaxLines="1"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>

                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource RynatMutedTextStyle}"
                                                Text="{Binding TypeLabel}" />

                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="0,0,14,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource RynatMutedTextStyle}"
                                                Text="{Binding SizeLabel}" />

                                            <TextBlock
                                                Grid.Column="3"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource RynatMutedTextStyle}"
                                                Text="{Binding ModifiedLabel}" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>

                <controls:ResizeSplitter
                    x:Name="PreviewPaneSplitter"
                    Grid.Column="3"
                    Background="Transparent"
                    PointerCanceled="PreviewPaneSplitter_PointerReleased"
                    PointerEntered="WorkspacePaneSplitter_PointerEntered"
                    PointerExited="WorkspacePaneSplitter_PointerExited"
                    PointerPressed="PreviewPaneSplitter_PointerPressed"
                    PointerReleased="PreviewPaneSplitter_PointerReleased"
                    PointerMoved="WorkspacePaneSplitter_PointerMoved"
                    Visibility="{x:Bind ViewModel.IsPreviewPaneVisible, Mode=OneWay}">
                    <Border
                        x:Name="PreviewPaneSplitterLine"
                        Width="1"
                        HorizontalAlignment="Center"
                        Background="Transparent" />
                </controls:ResizeSplitter>

                <Border
                    Grid.Column="4"
                    Background="{ThemeResource RynatPanelBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Visibility="{x:Bind ViewModel.IsPreviewPaneVisible, Mode=OneWay}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="54" />
                        </Grid.RowDefinitions>

                        <Grid
                            Padding="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource RynatInkBrush}"
                                Text="预览" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Style="{StaticResource RynatMutedTextStyle}"
                                Text="{x:Bind ViewModel.PreviewDirectorySummary, Mode=OneWay}" />
                        </Grid>

                        <ScrollViewer Grid.Row="1">
                            <StackPanel Padding="14,14" Spacing="14">
                                <Grid
                                    MinHeight="172"
                                    MaxHeight="300"
                                    Background="Transparent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="0"
                                        Visibility="{x:Bind ViewModel.IsPreviewLoading, Mode=OneWay}">
                                        <ProgressRing
                                            Width="18"
                                            Height="18"
                                            IsActive="True" />
                                    </StackPanel>

                                    <Border
                                        x:Name="PreviewImageContainer"
                                        Padding="8"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                        <Image
                                            x:Name="PreviewImage"
                                            Stretch="Uniform" />
                                    </Border>

                                    <FontIcon
                                        x:Name="PreviewFallbackIcon"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="96"
                                        Foreground="{ThemeResource RynatMutedBrush}"
                                        Glyph="{x:Bind ViewModel.PreviewPane.IconGlyph, Mode=OneWay}" />

                                </Grid>

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Spacing="4">
                                    <TextBlock
                                        MaxWidth="286"
                                        HorizontalAlignment="Center"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource RynatInkBrush}"
                                        MaxLines="2"
                                        Text="{x:Bind ViewModel.PreviewPane.Title, Mode=OneWay}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        MaxWidth="286"
                                        HorizontalAlignment="Center"
                                        Foreground="{ThemeResource RynatMutedBrush}"
                                        MaxLines="4"
                                        Text="{x:Bind ViewModel.PreviewPane.Description, Mode=OneWay}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <Border
                            Grid.Row="2"
                            Padding="14,8"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    Click="GenerateLinkButton_Click"
                                    IsEnabled="{x:Bind ViewModel.CanGenerateLink, Mode=OneWay}"
                                    Style="{StaticResource RynatPreviewActionButtonStyle}">
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                        <FontIcon FontSize="13" Glyph="&#xE71B;" />
                                        <TextBlock Text="复制链接" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Click="PlaySelectedVideoButton_Click"
                                    IsEnabled="{x:Bind ViewModel.CanPlaySelectedVideo, Mode=OneWay}"
                                    Style="{StaticResource RynatPreviewActionButtonStyle}">
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                        <FontIcon FontSize="13" Glyph="&#xE768;" />
                                        <TextBlock Text="播放" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Click="OpenDirectoryButton_Click"
                                    IsEnabled="{x:Bind ViewModel.CanOpenSelectedItem, Mode=OneWay}"
                                    Style="{StaticResource RynatPreviewActionButtonStyle}">
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="7">
                                        <FontIcon FontSize="13" Glyph="&#xE8A7;" />
                                        <TextBlock Text="打开" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border
                Grid.Row="2"
                Background="{ThemeResource RynatChromeBrush}"
                BorderBrush="Transparent"
                BorderThickness="0">
                <Grid Padding="16,3,16,5" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource RynatMutedTextStyle}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                    <Button
                        Grid.Column="1"
                        Width="280"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Right"
                        Click="CopyStatusPathButton_Click"
                        IsEnabled="{x:Bind ViewModel.CanCopySelectedPath, Mode=OneWay}"
                        Style="{StaticResource RynatPathButtonStyle}"
                        ToolTipService.ToolTip="复制路径">
                        <TextBlock
                            Foreground="{ThemeResource RynatFaintBrush}"
                            FontFamily="Consolas"
                            FontSize="10.5"
                            HorizontalAlignment="Right"
                            MaxLines="1"
                            Text="{x:Bind ViewModel.StatusPathText, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </Button>
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="10">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource RynatFaintBrush}"
                            MaxLines="1"
                            Text="{x:Bind ViewModel.ActiveTaskSummary, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{x:Bind ViewModel.HasActiveTask, Mode=OneWay}" />
                        <ProgressBar
                            Width="120"
                            Height="4"
                            Maximum="100"
                            Value="{x:Bind ViewModel.ActiveTaskProgress, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.HasActiveTask, Mode=OneWay}" />
                        <Button
                            Click="CancelActiveTaskButton_Click"
                            Content="取消"
                            IsEnabled="{x:Bind ViewModel.CanCancelActiveTask, Mode=OneWay}"
                            Style="{StaticResource RynatStatusButtonStyle}"
                            Visibility="{x:Bind ViewModel.HasActiveTask, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
