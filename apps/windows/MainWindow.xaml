<Window x:Class="Rynat.WindowsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:files="clr-namespace:Rynat.WindowsClient.UI.Files"
        xmlns:login="clr-namespace:Rynat.WindowsClient.UI.Login"
        xmlns:navigation="clr-namespace:Rynat.WindowsClient.UI.Navigation"
        xmlns:preview="clr-namespace:Rynat.WindowsClient.UI.Preview"
        xmlns:status="clr-namespace:Rynat.WindowsClient.UI.Status"
        Title="rynat 共享网盘"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <login:LoginView DataContext="{Binding Login}" />
        </Grid>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition x:Name="PreviewColumn" Width="320" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <navigation:NavigationTreeView Grid.Column="0"
                                           DataContext="{Binding Navigation}" />
            <files:FileListView Grid.Column="1" />
            <preview:PreviewPaneView Grid.Column="2"
                                     DataContext="{Binding Preview}">
                <preview:PreviewPaneView.Style>
                    <Style TargetType="preview:PreviewPaneView">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </preview:PreviewPaneView.Style>
            </preview:PreviewPaneView>
            <status:StatusBarView Grid.Row="1"
                                  Grid.ColumnSpan="3"
                                  DataContext="{Binding Status}" />
        </Grid>
    </Grid>
</Window>
