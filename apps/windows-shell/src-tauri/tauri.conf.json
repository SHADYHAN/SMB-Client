{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RYNAT",
  "version": "0.1.0",
  "identifier": "com.rynat.windows-shell",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RYNAT",
        "width": 520,
        "height": 620,
        "resizable": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
